# TEMPLATE -- copy to .streamlit/secrets.toml (which is excluded from git)
# to activate a PRIVATE calibration instead of the public default.
#
# On Streamlit Community Cloud: do NOT push this file with real values.
# Instead, paste these same values into the "Secrets" panel of the app
# dashboard (Settings -> Secrets) -- they stay encrypted, never in the repo.

[calibration]
q = 1.52
k_hf = 0.0141
w_a1c = 0.0144
w_uacr = 0.0180
w_sbp = 0.0108
